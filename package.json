{
  "name": "djass",
  "version": "1.0.0",
  "description": "Web app wrapper around django-saas-starter cookiecutter.",
  "scripts": {
    "build": "npm run build:vendor && npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i frontend/src/styles/index.css -o frontend/static/css/app.css --minify",
    "build:js": "node scripts/copy-app-js.mjs",
    "build:vendor": "node scripts/copy-vendor-assets.mjs",
    "watch": "npm run build:vendor && node scripts/watch-assets.mjs",
    "lint": "eslint \"frontend/src/js/**/*.js\" \"scripts/**/*.mjs\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rasulkireev/djass"
  },
  "keywords": [
    "django",
    "htmx",
    "alpine",
    "frontend"
  ],
  "author": "Rasul",
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0"
  },
  "bugs": {
    "url": "https://github.com/rasulkireev/djass/issues"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "eslint": "^8.57.1",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "alpinejs": "^3.15.12",
    "htmx.org": "^2.0.10",
    "mjml": "^4.15.3"
  }
}
