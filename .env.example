# If you deploying via docker compose you don't need to update these values:
# - POSTGRES_HOST
# - POSTGRES_PORT
# - REDIS_HOST
# - REDIS_PORT

# should be 'off' in prod
DEBUG=on

# options:
# - dev (for local development)
# - prod (for deployed versions)
ENVIRONMENT=dev

# Container role for the shared deployment image.
# Use "server" for the web app and "worker" for the background workers app.
DJASS_PROCESS_TYPE=server

SECRET_KEY="super-secret-key"

SITE_URL=http://localhost:8000

# Artifact/media storage path (mount as persistent volume in production)
MEDIA_ROOT=/data/media

POSTGRES_HOST=db
POSTGRES_DB=djass
POSTGRES_USER=djass
POSTGRES_PORT=5432
POSTGRES_PASSWORD=djass

REDIS_HOST=redis
REDIS_PASSWORD=djass
REDIS_PORT=6379

# If you want to enable Social Auth via Github
# Get his values after creating a new app on GitHub: https://github.com/settings/applications/new
# For Homepage URL use: http://localhost:8000
# For Authorization callback URL use: http://localhost:8000/accounts/github/login/callback/
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# If you want to load blog post images to S3, instead of local storage
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=djass
AWS_SECRET_ACCESS_KEY=djass
AWS_S3_BUCKET_NAME=djass

# If you need email sending capabilities
# This is not really necessary in the state of the app
# Apart from confirming the email.
# If you don't specify the key you will get the link to confirm email
# in your logs
MAILGUN_API_KEY=
# Mailgun sending domain
MAILGUN_SENDER_DOMAIN=mg.djass.dev
# Optional override; set to https://api.eu.mailgun.net for EU-region Mailgun accounts
MAILGUN_API_URL=
# Optional sender overrides
DEFAULT_FROM_EMAIL="Greg from Djass <greg@djass.dev>"
SERVER_EMAIL="Djass Errors <greg@djass.dev>"

# If you plan on doing a newsletter for subscribers
# Not really needed fo custom deployments, I think
BUTTONDOWN_API_KEY=

# MJML URL for self-hosted server
MJML_URL=http://mjml:15500

# depending on what AI provider you use, you can set the API key here.
# We are using PydanticAI so use names suggested in their docs:
# https://ai.pydantic.dev/models/
OPENAI_API_KEY=

LOGFIRE_TOKEN=
LOGFIRE_CONSOLE_SHOW_PROJECT_LINK=False

SENTRY_DSN=
SENTRY_ENABLED=False
SENTRY_ENVIRONMENT=dev
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=1.0
SENTRY_ENABLE_LOGS=True
SENTRY_SEND_DEFAULT_PII=False
SENTRY_INCLUDE_LOCAL_VARIABLES=False
SENTRY_MAX_BREADCRUMBS=100
# PII-sensitive: when enabled, Sentry AI monitoring can include LLM/tool prompts and responses.
SENTRY_AI_INCLUDE_PROMPTS=False
SENTRY_AI_HANDLED_TOOL_CALL_EXCEPTIONS=True
# PostHog project API key (phc_...) used for frontend + server-side capture
POSTHOG_API_KEY=
# PostHog ingest host (US default). Use https://eu.i.posthog.com for EU projects.
POSTHOG_HOST=https://us.i.posthog.com
